<Window
    x:Class="CornerstoneQueue.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Cornerstone 样品队列">

  <Grid x:Name="DockRoot" Padding="8,6" RowSpacing="4">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6">
      <Ellipse x:Name="DotBridge" Width="8" Height="8" VerticalAlignment="Center" Fill="Gray" />
      <TextBlock
        x:Name="TxtStatusLine"
        VerticalAlignment="Center"
        FontSize="11"
        TextTrimming="CharacterEllipsis"
        TextWrapping="NoWrap"
        Text="…" />
    </StackPanel>

    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6">
      <Button
        x:Name="BtnRefresh"
        Padding="8,4"
        FontSize="12"
        Content="刷新"
        Click="OnRefreshClick" />
      <Button
        x:Name="BtnSettings"
        Padding="8,4"
        FontSize="12"
        Content="设置"
        Click="OnSettingsClick" />
      <Button
        x:Name="BtnSend"
        Padding="8,4"
        FontSize="12"
        Content="发送"
        Style="{StaticResource AccentButtonStyle}"
        Click="OnSendClick" />
    </StackPanel>

    <ListView
      Grid.Row="2"
      x:Name="QueueList"
      MinHeight="72"
      MaxHeight="280"
      FontFamily="{StaticResource QueueMonoFont}"
      SelectionMode="Extended"
      IsItemClickEnabled="True"
      DoubleTapped="OnQueueListDoubleTapped">
      <ListView.ItemContainerStyle>
        <Style TargetType="ListViewItem">
          <Setter Property="MinHeight" Value="24" />
          <Setter Property="Padding" Value="4,2" />
          <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
      </ListView.ItemContainerStyle>
      <ListView.ItemTemplate>
        <DataTemplate>
          <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock
              FontFamily="{StaticResource QueueMonoFont}"
              Text="{Binding SampleNameDisplay}"
              TextTrimming="CharacterEllipsis"
              TextWrapping="NoWrap" />
            <TextBlock
              Grid.Column="1"
              FontFamily="{StaticResource QueueMonoFont}"
              Text="{Binding SampleDescriptionDisplay}"
              TextTrimming="CharacterEllipsis"
              TextWrapping="NoWrap" />
          </Grid>
        </DataTemplate>
      </ListView.ItemTemplate>
    </ListView>

    <TextBlock
      Grid.Row="3"
      x:Name="TxtResultLine"
      FontSize="11"
      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
      TextTrimming="CharacterEllipsis"
      TextWrapping="NoWrap"
      Visibility="Collapsed" />
  </Grid>
</Window>
